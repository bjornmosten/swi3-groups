#!/usr/bin/env bash
# Wrapper for the swi3-groups Rust binary.

# Detect the base directory of this script to locate the binary.
_SCRIPT_DIR="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
_BINARY_PATH="${_SCRIPT_DIR}/../swi3-groups-client/target/release/swi3-groups"

# Fallback to a system-installed version if the local build is not found.
if [[ ! -x "${_BINARY_PATH}" ]]; then
  _BINARY_PATH="swi3-groups"
fi

exec "${_BINARY_PATH}" "$@"
