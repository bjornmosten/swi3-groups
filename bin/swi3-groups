#!/usr/bin/env bash

# swi3-groups — unified workspace group manager for i3 and sway.
# See https://vaneyckt.io/posts/safer_bash_scripts_with_set_euxo_pipefail/
set -o errexit -o errtrace -o nounset -o pipefail

# shellcheck source=_swi3-groups-common.sh
source "$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/_swi3-groups-common.sh"

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

_tool() {
  get_tool "${SWI3GROUPS_CLI:-swi3-groups-client}"
}

# ---------------------------------------------------------------------------
# select-group — internal helper (prompts user to pick a group via menu)
# ---------------------------------------------------------------------------

readonly _DEFAULT_GROUP_ITEM='<default>'

_list_groups() {
  local tool="$1"
  local named_groups
  named_groups="$("${tool}" list-groups | grep -v '^$' || true)"
  echo ''
  if [[ -n "${named_groups}" ]]; then
    printf '%s\n' "${named_groups}"
  fi
}

cmd_select_group() {
  local tool
  tool="$(_tool)"
  _build_menu_cmd 'Workspace Group' '' 'window {width: 60ch;} listview {lines: 10;}'
  # Append caller-supplied args (e.g. -mesg) only for backends that support them.
  [[ "${_MENU_CMD}" != "wofi" ]] && _MENU_ARGS+=("$@")
  local group
  if ! group="$(
    _list_groups "${tool}" |
      sed -r 's|^$|'"${_DEFAULT_GROUP_ITEM}"'|' |
      "${_MENU_ARGS[@]}"
  )"; then
    exit 1
  fi
  if [[ "${group}" == "${_DEFAULT_GROUP_ITEM}" ]]; then
    group=''
  fi
  printf '%s' "${group}"
}

# ---------------------------------------------------------------------------
# switch-group — select and activate a workspace group
# ---------------------------------------------------------------------------

cmd_switch_group() {
  local select_groups
  select_groups="$(get_tool swi3-groups)"
  local help_heading='Select a workspace group to activate.'
  local help_content='You can create a new group by typing a new name.
Note that the default group is shown as &lt;default>.'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
<i>%s</i></span>'
  # shellcheck disable=SC2059
  local help_text
  help_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"

  local group
  if ! group="$("${select_groups}" select-group -mesg "${help_text}")"; then
    exit 1
  fi
  local tool
  tool="$(_tool)"
  "${tool}" "$@" switch-active-group "${group}"
}

# ---------------------------------------------------------------------------
# assign — assign focused workspace to a group
# ---------------------------------------------------------------------------

cmd_assign() {
  local select_groups
  select_groups="$(get_tool swi3-groups)"
  local help_heading='Select a group to assign to the focused workspace.'
  local help_content='You can assign it to a new group by typing a new name.
Note that the default group is shown as &lt;default>.'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
<i>%s</i></span>'
  # shellcheck disable=SC2059
  local help_text
  help_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"

  local group
  if ! group="$("${select_groups}" select-group -mesg "${help_text}")"; then
    exit 1
  fi
  local tool
  tool="$(_tool)"
  "${tool}" "$@" assign-workspace-to-group "${group}"
}

# ---------------------------------------------------------------------------
# prev-workspace — focus the previous workspace in the active group
# ---------------------------------------------------------------------------

cmd_prev_workspace() {
  local tool
  tool="$(_tool)"
  "${tool}" workspace-prev
}

# ---------------------------------------------------------------------------
# assign-switch — assign focused workspace to a group and switch to it
# ---------------------------------------------------------------------------

cmd_assign_switch() {
  local select_groups
  select_groups="$(get_tool swi3-groups)"
  local help_heading='Select a group to assign the focused workspace to and switch to.'
  local help_content='You can assign it to a new group by typing a new name.
Note that the default group is shown as &lt;default>.'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
<i>%s</i></span>'
  # shellcheck disable=SC2059
  local help_text
  help_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"

  local group
  if ! group="$("${select_groups}" select-group -mesg "${help_text}")"; then
    exit 1
  fi
  local tool
  tool="$(_tool)"
  "${tool}" "$@" assign-workspace-to-group "${group}"
  "${tool}" "$@" switch-active-group "${group}"
}

# ---------------------------------------------------------------------------
# focus — focus on a workspace chosen from a menu
# ---------------------------------------------------------------------------

cmd_focus() {
  local help_heading='Select a workspace to focus on'
  local help_content='You can focus on a new (non existing) workspace by using the format "group:number", for example "work:2"'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
<i>%s</i></span>'
  # shellcheck disable=SC2059
  local help_text
  help_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"

  _build_menu_cmd 'Workspace' "${help_text}" 'window {width: 60ch;}'

  local tool
  tool="$(_tool)"
  local workspaces displayed_workspaces
  mapfile -t workspaces < <("${tool}" list-workspaces --fields 'global_name')
  mapfile -t displayed_workspaces < <("${tool}" list-workspaces \
    --fields 'set,local_number,window_icons,static_name' |
    column -t -s $'\t' -o '    ')

  local selected
  if ! selected="$(printf '%s\n' "${displayed_workspaces[@]}" |
    "${_MENU_ARGS[@]}")"; then
    exit 1
  fi

  local i line
  for i in "${!displayed_workspaces[@]}"; do
    line="${displayed_workspaces[${i}]}"
    if [[ "${line}" == "${selected}" ]]; then
      wm_msg workspace "\"${workspaces[${i}]}\""
      exit
    fi
  done
  # No existing workspace selected — assume "group:local_number" format.
  local group local_number
  group="${selected%%:*}"
  local_number="${selected##*:}"
  "${tool}" workspace-number --group-name "${group}" "${local_number}"
}

# ---------------------------------------------------------------------------
# move — move focused container to a workspace chosen from a menu
# ---------------------------------------------------------------------------

cmd_move() {
  local help_heading='Select a workspace to move the focused container into'
  local help_content='You can select a new (non existing) workspace by using the format "group:number", for example "work:2".
Displayed table columns: group, number, window icons, and name.'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
<i>%s</i></span>'
  # shellcheck disable=SC2059
  local help_text
  help_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"

  local displayed_fields='set,local_number,window_icons,static_name'
  _build_menu_cmd 'Workspace' "${help_text}" 'window {width: 60ch;}'

  local tool
  tool="$(_tool)"
  local displayed_workspaces
  mapfile -t displayed_workspaces < <(
    "${tool}" list-workspaces --fields "${displayed_fields}" |
      column -t -s $'\t' -o '    '
  )

  local selected
  if ! selected="$(printf '%s\n' "${displayed_workspaces[@]}" |
    "${_MENU_ARGS[@]}")"; then
    exit 1
  fi

  local workspaces
  mapfile -t workspaces < <("${tool}" list-workspaces --fields 'global_name')
  local i line
  for i in "${!displayed_workspaces[@]}"; do
    line="${displayed_workspaces[${i}]}"
    if [[ "${line}" == "${selected}" ]]; then
      wm_msg move container to workspace "\"${workspaces[${i}]}\""
      exit
    fi
  done
  # No existing workspace selected — assume "group:local_number" format.
  local group local_number
  group="${selected%%:*}"
  local_number="${selected##*:}"
  "${tool}" move-to-number --group-name "${group}" "${local_number}"
}

# ---------------------------------------------------------------------------
# rename — rename the focused workspace
# ---------------------------------------------------------------------------

_rename_error() {
  local error normal
  error="$(tput setaf 1 2> /dev/null)" || true
  normal="$(tput sgr0 2> /dev/null)" || true
  printf >&2 '%s\n' "${error}${*}${normal}"
}

_do_rename() {
  local tool="$1" name_pattern="$2"
  local fields
  mapfile -d ':' -t fields < <(printf '%s' "${name_pattern}")
  local num_fields=${#fields[@]}
  if ((num_fields == 0)); then
    fields=('')
    num_fields=1
  fi
  local static_name_arg=() local_number_arg=() group_arg=()
  if ((num_fields == 1)); then
    static_name_arg=('--name' "${fields[0]}")
  elif ((num_fields == 2)); then
    [[ -n "${fields[0]}" ]] && static_name_arg=('--name' "${fields[0]}")
    [[ -n "${fields[1]}" ]] && local_number_arg=('--number' "${fields[1]}")
  elif ((num_fields == 3)); then
    [[ -n "${fields[0]}" ]] && group_arg=('--set' "${fields[0]}")
    [[ -n "${fields[1]}" ]] && static_name_arg=('--name' "${fields[1]}")
    [[ -n "${fields[2]}" ]] && local_number_arg=('--number' "${fields[2]}")
  else
    _rename_error 'Name pattern cannot contain more than 3 colons'
    exit 3
  fi
  [[ "${static_name_arg[1]:-}" == '-' ]] && static_name_arg[1]=''
  [[ "${local_number_arg[1]:-}" == '-' ]] && local_number_arg[1]=''
  [[ "${group_arg[1]:-}" == '-' ]] && group_arg[1]=''
  "${tool}" rename-workspace "${static_name_arg[@]}" "${local_number_arg[@]}" \
    "${group_arg[@]}"
}

cmd_rename() {
  local help_heading_format='Enter a new name for workspace "%s"'
  local help_content_format='<i>By default only the name is changed, but you can also use colons to change the number or group. In addition, you can use an hyphen ("-") to reset a property.
Example inputs and what properties they change:</i> %s'
  local help_examples='
+-----------+-------------------------------------+
|   Input   |              Changes                |
+-----------+-------------------------------------+
| foo       | name="foo"                          |
| foo:2     | name="foo", number=2                |
| -:2       | name="", number=2                   |
| :2        | number=2                            |
| bar:foo:2 | group="bar", name="foo", number=2   |
| bar::2    | group="bar", number=2               |
+-----------+-------------------------------------+'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
%s</span>'
  local tool
  tool="$(_tool)"
  local mesg_text=''
  local current_name
  if current_name="$("${tool}" list-workspaces --fields static_name \
    --focused-only)"; then
    local help_heading help_content
    # shellcheck disable=SC2059
    help_heading="$(printf "${help_heading_format}" "${current_name}")"
    # shellcheck disable=SC2059
    help_content="$(printf "${help_content_format}" "${help_examples}")"
    # shellcheck disable=SC2059
    mesg_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"
  fi
  _build_menu_cmd 'Rename' "${mesg_text}" 'window {width: 60ch;} listview {lines: 0;}'

  local new_name_pattern
  if ! new_name_pattern="$("${_MENU_ARGS[@]}")"; then
    exit 1
  fi
  _do_rename "${tool}" "${new_name_pattern}"
}

# ---------------------------------------------------------------------------
# polybar — polybar module output
# ---------------------------------------------------------------------------

cmd_polybar() {
  local COLOR_EXTERNAL_MONITOR=""
  local COLOR_CURRENT_WS=""
  local SHORTHAND_ENABLED=0

  while getopts c:e:s flag; do
    case "${flag}" in
      e) COLOR_EXTERNAL_MONITOR=${OPTARG} ;;
      c) COLOR_CURRENT_WS=${OPTARG} ;;
      s) SHORTHAND_ENABLED=1 ;;
      *) echo "Options: -c \"#HEXCOLOR\" (current ws), -e \"#HEXCOLOR\" (external monitor), -s (shorthand)" ;;
    esac
  done

  local tool
  tool="$(_tool)"

  _ows() {
    local ws_num="$1" group="$2"
    [[ "${group}" == "default" ]] && group=""
    echo "swi3-groups workspace-number ${ws_num} --group-name \"${group}\""
  }

  _ch_st() {
    local group="$1"
    [[ "${group}" == "default" ]] && group=""
    echo "swi3-groups switch-active-group \"${group}\""
  }

  _txt_item() {
    local display="$1" group="$2" ws_num="$3" global_num="$4"
    local ws_screen=$(( global_num / 100000 ))
    if [[ ${ws_screen} -eq 0 ]] || [[ -z "${COLOR_EXTERNAL_MONITOR}" ]]; then
      echo "%{A1:$(_ows "${ws_num}" "${group}"):}${display}%{A}"
    else
      local w
      w=$(echo "${display}" | sed -e "s/\([^0-9]*\)\([[:digit:]]\+\)\([^0-9]*\)/\1%{F${COLOR_EXTERNAL_MONITOR}}\2%{F-}\3/")
      echo "%{A1:$(_ows "${ws_num}" "${group}"):}${w}%{A}"
    fi
  }

  mapfile -t ws_data < <("${tool}" list-workspaces \
    --fields 'global_number,set,local_number,focused')

  declare -a ws_globals ws_groups ws_locals ws_focused
  local line
  for line in "${ws_data[@]}"; do
    IFS=$'\t' read -r g st l f <<< "${line}"
    ws_globals+=("${g}")
    ws_groups+=("${st}")
    ws_locals+=("${l}")
    ws_focused+=("${f}")
  done

  local current_group="" current_local=""
  local i
  for i in "${!ws_focused[@]}"; do
    if [[ "${ws_focused[${i}]}" == "True" ]]; then
      current_group="${ws_groups[${i}]}"
      current_local="${ws_locals[${i}]}"
      break
    fi
  done

  declare -a seen_groups
  declare -A seen_group_map
  local st
  for st in "${ws_groups[@]}"; do
    if [[ -z "${seen_group_map[${st}]+x}" ]]; then
      seen_groups+=("${st}")
      seen_group_map["${st}"]=1
    fi
  done

  local text=""
  local group
  for group in "${seen_groups[@]}"; do
    local display_group="${group:-default}"
    text="${text}%{A1:$(_ch_st "${display_group}"):}${display_group}:%{A}"

    declare -a st_locals st_globals
    st_locals=()
    st_globals=()
    for i in "${!ws_groups[@]}"; do
      if [[ "${ws_groups[${i}]}" == "${group}" ]]; then
        st_locals+=("${ws_locals[${i}]}")
        st_globals+=("${ws_globals[${i}]}")
      fi
    done

    local local_count=${#st_locals[@]}
    local prev_local="${st_locals[0]}"
    local last_local="${st_locals[$((local_count - 1))]}"
    local seq_count=1
    local j ws_num ws_long prev_long=""

    for j in $(seq 0 $((local_count - 1))); do
      ws_num="${st_locals[${j}]}"
      ws_long="${st_globals[${j}]}"

      if [[ "${ws_num}" == "${current_local}" ]] && [[ "${group}" == "${current_group}" ]]; then
        text="${text}%{u#a3be8c}%{+u} %{F${COLOR_CURRENT_WS}}$(_txt_item "${ws_num}" "${display_group}" "${ws_num}" "${ws_long}")%{F-} %{-u}"
      elif [[ "${group}" == "${current_group}" ]] || [[ "${SHORTHAND_ENABLED}" != "1" ]]; then
        text="${text}$(_txt_item " ${ws_num} " "${display_group}" "${ws_num}" "${ws_long}")"
      else
        if [[ "${j}" -eq 0 ]]; then
          text="${text}$(_txt_item " ${ws_num}" "${display_group}" "${ws_num}" "${ws_long}")"
        elif ((ws_num > prev_local + 1)); then
          if [[ ${seq_count} -gt 2 ]]; then
            text="${text}$(_txt_item "-${prev_local}" "${display_group}" "${prev_local}" "${prev_long}")"
          elif [[ ${seq_count} -eq 2 ]]; then
            text="${text}$(_txt_item ", ${prev_local}" "${display_group}" "${prev_local}" "${prev_long}")"
          fi
          text="${text}$(_txt_item ", ${ws_num}" "${display_group}" "${ws_num}" "${ws_long}")"
          seq_count=1
        elif [[ "${ws_num}" == "${last_local}" ]]; then
          if [[ ${seq_count} -gt 1 ]]; then
            text="${text}$(_txt_item "-${ws_num}" "${display_group}" "${ws_num}" "${ws_long}")"
          else
            text="${text}$(_txt_item ", ${ws_num}" "${display_group}" "${ws_num}" "${ws_long}")"
          fi
        else
          seq_count=$((seq_count + 1))
        fi
        prev_local="${ws_num}"
        prev_long="${ws_long}"
      fi
    done
    text="${text} | "
  done

  text="${text% | }"
  echo "${text}"
}

# ---------------------------------------------------------------------------
# Dispatcher
# ---------------------------------------------------------------------------

usage() {
  cat <<EOF
Usage: swi3-groups <command> [args...]

Commands:
  switch-group    Select and activate a workspace group
  assign          Assign focused workspace to a group
  assign-and-switch  Assign focused workspace to a group and switch to it
  focus           Focus on a workspace selected from a menu
  move            Move focused container to a workspace
  rename          Rename the focused workspace
  prev-workspace  Focus the previous workspace in the active set
  polybar         Output polybar module text
  waybar          Output waybar module JSON

Any other command is passed directly to swi3-groups-client.
EOF
}

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  local cmd="$1"
  shift

  case "${cmd}" in
    switch-group)   cmd_switch_group "$@" ;;
    assign)         cmd_assign "$@" ;;
    assign-and-switch)  cmd_assign_switch "$@" ;;
    focus)          cmd_focus "$@" ;;
    move)           cmd_move "$@" ;;
    rename)         cmd_rename "$@" ;;
    prev-workspace) cmd_prev_workspace "$@" ;;
    polybar)        cmd_polybar "$@" ;;
    select-group)   cmd_select_group "$@" ;;
    *)
      local tool
      tool="$(_tool)"
      "${tool}" "${cmd}" "$@"
      ;;
  esac
}

main "$@"
