#!/usr/bin/env bash

# swi3-sets — unified workspace set manager for i3 and sway.
# See https://vaneyckt.io/posts/safer_bash_scripts_with_set_euxo_pipefail/
set -o errexit -o errtrace -o nounset -o pipefail

# shellcheck source=_swi3-sets-common.sh
source "$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/_swi3-sets-common.sh"

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

_tool() {
  get_tool "${SWI3SETS_CLI:-swi3-sets-client}"
}

# ---------------------------------------------------------------------------
# select-set — internal helper (prompts user to pick a set via menu)
# ---------------------------------------------------------------------------

readonly _DEFAULT_SET_ITEM='<default>'

_list_sets() {
  local tool="$1"
  local named_sets
  named_sets="$("${tool}" list-sets | grep -v '^$' || true)"
  echo ''
  if [[ -n "${named_sets}" ]]; then
    printf '%s\n' "${named_sets}"
  fi
}

cmd_select_set() {
  local tool
  tool="$(_tool)"
  _build_menu_cmd 'Workspace Set' '' 'window {width: 60ch;} listview {lines: 10;}'
  # Append caller-supplied args (e.g. -mesg) only for backends that support them.
  [[ "${_MENU_CMD}" != "wofi" ]] && _MENU_ARGS+=("$@")
  local set
  if ! set="$(
    _list_sets "${tool}" |
      sed -r 's|^$|'"${_DEFAULT_SET_ITEM}"'|' |
      "${_MENU_ARGS[@]}"
  )"; then
    exit 1
  fi
  if [[ "${set}" == "${_DEFAULT_SET_ITEM}" ]]; then
    set=''
  fi
  printf '%s' "${set}"
}

# ---------------------------------------------------------------------------
# switch-set — select and activate a workspace set
# ---------------------------------------------------------------------------

cmd_switch_set() {
  local select_sets
  select_sets="$(get_tool swi3-sets)"
  local help_heading='Select a workspace set to activate.'
  local help_content='You can create a new set by typing a new name.
Note that the default set is shown as &lt;default>.'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
<i>%s</i></span>'
  # shellcheck disable=SC2059
  local help_text
  help_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"

  local set
  if ! set="$("${select_sets}" select-set -mesg "${help_text}")"; then
    exit 1
  fi
  local tool
  tool="$(_tool)"
  "${tool}" "$@" switch-active-set "${set}"
}

# ---------------------------------------------------------------------------
# assign — assign focused workspace to a set
# ---------------------------------------------------------------------------

cmd_assign() {
  local select_sets
  select_sets="$(get_tool swi3-sets)"
  local help_heading='Select a set to assign to the focused workspace.'
  local help_content='You can assign it to a new set by typing a new name.
Note that the default set is shown as &lt;default>.'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
<i>%s</i></span>'
  # shellcheck disable=SC2059
  local help_text
  help_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"

  local set
  if ! set="$("${select_sets}" select-set -mesg "${help_text}")"; then
    exit 1
  fi
  local tool
  tool="$(_tool)"
  "${tool}" "$@" assign-workspace-to-set "${set}"
}

# ---------------------------------------------------------------------------
# focus — focus on a workspace chosen from a menu
# ---------------------------------------------------------------------------

cmd_focus() {
  local help_heading='Select a workspace to focus on'
  local help_content='You can focus on a new (non existing) workspace by using the format "set:number", for example "work:2"'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
<i>%s</i></span>'
  # shellcheck disable=SC2059
  local help_text
  help_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"

  _build_menu_cmd 'Workspace' "${help_text}" 'window {width: 60ch;}'

  local tool
  tool="$(_tool)"
  local workspaces displayed_workspaces
  mapfile -t workspaces < <("${tool}" list-workspaces --fields 'global_name')
  mapfile -t displayed_workspaces < <("${tool}" list-workspaces \
    --fields 'set,local_number,window_icons,static_name' |
    column -t -s $'\t' -o '    ')

  local selected
  if ! selected="$(printf '%s\n' "${displayed_workspaces[@]}" |
    "${_MENU_ARGS[@]}")"; then
    exit 1
  fi

  local i line
  for i in "${!displayed_workspaces[@]}"; do
    line="${displayed_workspaces[${i}]}"
    if [[ "${line}" == "${selected}" ]]; then
      wm_msg workspace "\"${workspaces[${i}]}\""
      exit
    fi
  done
  # No existing workspace selected — assume "set:local_number" format.
  local set local_number
  set="${selected%%:*}"
  local_number="${selected##*:}"
  "${tool}" workspace-number --set-name "${set}" "${local_number}"
}

# ---------------------------------------------------------------------------
# move — move focused container to a workspace chosen from a menu
# ---------------------------------------------------------------------------

cmd_move() {
  local help_heading='Select a workspace to move the focused container into'
  local help_content='You can select a new (non existing) workspace by using the format "set:number", for example "work:2".
Displayed table columns: set, number, window icons, and name.'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
<i>%s</i></span>'
  # shellcheck disable=SC2059
  local help_text
  help_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"

  local displayed_fields='set,local_number,window_icons,static_name'
  _build_menu_cmd 'Workspace' "${help_text}" 'window {width: 60ch;}'

  local tool
  tool="$(_tool)"
  local displayed_workspaces
  mapfile -t displayed_workspaces < <(
    "${tool}" list-workspaces --fields "${displayed_fields}" |
      column -t -s $'\t' -o '    '
  )

  local selected
  if ! selected="$(printf '%s\n' "${displayed_workspaces[@]}" |
    "${_MENU_ARGS[@]}")"; then
    exit 1
  fi

  local workspaces
  mapfile -t workspaces < <("${tool}" list-workspaces --fields 'global_name')
  local i line
  for i in "${!displayed_workspaces[@]}"; do
    line="${displayed_workspaces[${i}]}"
    if [[ "${line}" == "${selected}" ]]; then
      wm_msg move container to workspace "\"${workspaces[${i}]}\""
      exit
    fi
  done
  # No existing workspace selected — assume "set:local_number" format.
  local set local_number
  set="${selected%%:*}"
  local_number="${selected##*:}"
  "${tool}" move-to-number --set-name "${set}" "${local_number}"
}

# ---------------------------------------------------------------------------
# rename — rename the focused workspace
# ---------------------------------------------------------------------------

_rename_error() {
  local error normal
  error="$(tput setaf 1 2> /dev/null)" || true
  normal="$(tput sgr0 2> /dev/null)" || true
  printf >&2 '%s\n' "${error}${*}${normal}"
}

_do_rename() {
  local tool="$1" name_pattern="$2"
  local fields
  mapfile -d ':' -t fields < <(printf '%s' "${name_pattern}")
  local num_fields=${#fields[@]}
  if ((num_fields == 0)); then
    fields=('')
    num_fields=1
  fi
  local static_name_arg=() local_number_arg=() set_arg=()
  if ((num_fields == 1)); then
    static_name_arg=('--name' "${fields[0]}")
  elif ((num_fields == 2)); then
    [[ -n "${fields[0]}" ]] && static_name_arg=('--name' "${fields[0]}")
    [[ -n "${fields[1]}" ]] && local_number_arg=('--number' "${fields[1]}")
  elif ((num_fields == 3)); then
    [[ -n "${fields[0]}" ]] && set_arg=('--set' "${fields[0]}")
    [[ -n "${fields[1]}" ]] && static_name_arg=('--name' "${fields[1]}")
    [[ -n "${fields[2]}" ]] && local_number_arg=('--number' "${fields[2]}")
  else
    _rename_error 'Name pattern cannot contain more than 3 colons'
    exit 3
  fi
  [[ "${static_name_arg[1]:-}" == '-' ]] && static_name_arg[1]=''
  [[ "${local_number_arg[1]:-}" == '-' ]] && local_number_arg[1]=''
  [[ "${set_arg[1]:-}" == '-' ]] && set_arg[1]=''
  "${tool}" rename-workspace "${static_name_arg[@]}" "${local_number_arg[@]}" \
    "${set_arg[@]}"
}

cmd_rename() {
  local help_heading_format='Enter a new name for workspace "%s"'
  local help_content_format='<i>By default only the name is changed, but you can also use colons to change the number or set, In addition, you can use an hyphen ("-") to reset a property.
Example inputs and what properties they change:</i> %s'
  local help_examples='
+-----------+-----------------------------------+
|   Input   |              Changes              |
+-----------+-----------------------------------+
| foo       | name="foo"                        |
| foo:2     | name="foo", number=2              |
| -:2       | name="", number=2                 |
| :2        | number=2                          |
| bar:foo:2 | set="bar", name="foo", number=2   |
| bar::2    | set="bar", number=2               |
+-----------+-----------------------------------+'
  local help_format='<span alpha="50%%" size="smaller"><b>%s</b>
%s</span>'
  local tool
  tool="$(_tool)"
  local mesg_text=''
  local current_name
  if current_name="$("${tool}" list-workspaces --fields static_name \
    --focused-only)"; then
    local help_heading help_content
    # shellcheck disable=SC2059
    help_heading="$(printf "${help_heading_format}" "${current_name}")"
    # shellcheck disable=SC2059
    help_content="$(printf "${help_content_format}" "${help_examples}")"
    # shellcheck disable=SC2059
    mesg_text="$(printf "${help_format}" "${help_heading}" "${help_content}")"
  fi
  _build_menu_cmd 'Rename' "${mesg_text}" 'window {width: 60ch;} listview {lines: 0;}'

  local new_name_pattern
  if ! new_name_pattern="$("${_MENU_ARGS[@]}")"; then
    exit 1
  fi
  _do_rename "${tool}" "${new_name_pattern}"
}

# ---------------------------------------------------------------------------
# polybar — polybar module output
# ---------------------------------------------------------------------------

cmd_polybar() {
  local COLOR_EXTERNAL_MONITOR=""
  local COLOR_CURRENT_WS=""
  local SHORTHAND_ENABLED=0

  while getopts c:e:s flag; do
    case "${flag}" in
      e) COLOR_EXTERNAL_MONITOR=${OPTARG} ;;
      c) COLOR_CURRENT_WS=${OPTARG} ;;
      s) SHORTHAND_ENABLED=1 ;;
      *) echo "Options: -c \"#HEXCOLOR\" (current ws), -e \"#HEXCOLOR\" (external monitor), -s (shorthand)" ;;
    esac
  done

  local tool
  tool="$(_tool)"

  _ows() {
    local ws_num="$1" set="$2"
    [[ "${set}" == "default" ]] && set=""
    echo "swi3-sets workspace-number ${ws_num} --set-name \"${set}\""
  }

  _ch_st() {
    local set="$1"
    [[ "${set}" == "default" ]] && set=""
    echo "swi3-sets switch-active-set \"${set}\""
  }

  _txt_item() {
    local display="$1" set="$2" ws_num="$3" global_num="$4"
    local ws_screen=$(( global_num / 100000 ))
    if [[ ${ws_screen} -eq 0 ]] || [[ -z "${COLOR_EXTERNAL_MONITOR}" ]]; then
      echo "%{A1:$(_ows "${ws_num}" "${set}"):}${display}%{A}"
    else
      local w
      w=$(echo "${display}" | sed -e "s/\([^0-9]*\)\([[:digit:]]\+\)\([^0-9]*\)/\1%{F${COLOR_EXTERNAL_MONITOR}}\2%{F-}\3/")
      echo "%{A1:$(_ows "${ws_num}" "${set}"):}${w}%{A}"
    fi
  }

  mapfile -t ws_data < <("${tool}" list-workspaces \
    --fields 'global_number,set,local_number,focused')

  declare -a ws_globals ws_sets ws_locals ws_focused
  local line
  for line in "${ws_data[@]}"; do
    IFS=$'\t' read -r g st l f <<< "${line}"
    ws_globals+=("${g}")
    ws_sets+=("${st}")
    ws_locals+=("${l}")
    ws_focused+=("${f}")
  done

  local current_set="" current_local=""
  local i
  for i in "${!ws_focused[@]}"; do
    if [[ "${ws_focused[${i}]}" == "True" ]]; then
      current_set="${ws_sets[${i}]}"
      current_local="${ws_locals[${i}]}"
      break
    fi
  done

  declare -a seen_sets
  declare -A seen_set_map
  local st
  for st in "${ws_sets[@]}"; do
    if [[ -z "${seen_set_map[${st}]+x}" ]]; then
      seen_sets+=("${st}")
      seen_set_map["${st}"]=1
    fi
  done

  local text=""
  local set
  for set in "${seen_sets[@]}"; do
    local display_set="${set:-default}"
    text="${text}%{A1:$(_ch_st "${display_set}"):}${display_set}:%{A}"

    declare -a st_locals st_globals
    st_locals=()
    st_globals=()
    for i in "${!ws_sets[@]}"; do
      if [[ "${ws_sets[${i}]}" == "${set}" ]]; then
        st_locals+=("${ws_locals[${i}]}")
        st_globals+=("${ws_globals[${i}]}")
      fi
    done

    local local_count=${#st_locals[@]}
    local prev_local="${st_locals[0]}"
    local last_local="${st_locals[$((local_count - 1))]}"
    local seq_count=1
    local j ws_num ws_long prev_long=""

    for j in $(seq 0 $((local_count - 1))); do
      ws_num="${st_locals[${j}]}"
      ws_long="${st_globals[${j}]}"

      if [[ "${ws_num}" == "${current_local}" ]] && [[ "${set}" == "${current_set}" ]]; then
        text="${text}%{u#a3be8c}%{+u} %{F${COLOR_CURRENT_WS}}$(_txt_item "${ws_num}" "${display_set}" "${ws_num}" "${ws_long}")%{F-} %{-u}"
      elif [[ "${set}" == "${current_set}" ]] || [[ "${SHORTHAND_ENABLED}" != "1" ]]; then
        text="${text}$(_txt_item " ${ws_num} " "${display_set}" "${ws_num}" "${ws_long}")"
      else
        if [[ "${j}" -eq 0 ]]; then
          text="${text}$(_txt_item " ${ws_num}" "${display_set}" "${ws_num}" "${ws_long}")"
        elif ((ws_num > prev_local + 1)); then
          if [[ ${seq_count} -gt 2 ]]; then
            text="${text}$(_txt_item "-${prev_local}" "${display_set}" "${prev_local}" "${prev_long}")"
          elif [[ ${seq_count} -eq 2 ]]; then
            text="${text}$(_txt_item ", ${prev_local}" "${display_set}" "${prev_local}" "${prev_long}")"
          fi
          text="${text}$(_txt_item ", ${ws_num}" "${display_set}" "${ws_num}" "${ws_long}")"
          seq_count=1
        elif [[ "${ws_num}" == "${last_local}" ]]; then
          if [[ ${seq_count} -gt 1 ]]; then
            text="${text}$(_txt_item "-${ws_num}" "${display_set}" "${ws_num}" "${ws_long}")"
          else
            text="${text}$(_txt_item ", ${ws_num}" "${display_set}" "${ws_num}" "${ws_long}")"
          fi
        else
          seq_count=$((seq_count + 1))
        fi
        prev_local="${ws_num}"
        prev_long="${ws_long}"
      fi
    done
    text="${text} | "
  done

  text="${text% | }"
  echo "${text}"
}

# ---------------------------------------------------------------------------
# Dispatcher
# ---------------------------------------------------------------------------

usage() {
  cat <<EOF
Usage: swi3-sets <command> [args...]

Commands:
  switch-set      Select and activate a workspace set
  assign          Assign focused workspace to a set
  focus           Focus on a workspace selected from a menu
  move            Move focused container to a workspace
  rename          Rename the focused workspace
  polybar         Output polybar module text
  waybar          Output waybar module JSON

Any other command is passed directly to swi3-sets-client.
EOF
}

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  local cmd="$1"
  shift

  case "${cmd}" in
    switch-set)    cmd_switch_set "$@" ;;
    assign)        cmd_assign "$@" ;;
    focus)         cmd_focus "$@" ;;
    move)          cmd_move "$@" ;;
    rename)        cmd_rename "$@" ;;
    polybar)       cmd_polybar "$@" ;;
    select-set)    cmd_select_set "$@" ;;
    *)
      local tool
      tool="$(_tool)"
      "${tool}" "${cmd}" "$@"
      ;;
  esac
}

main "$@"
